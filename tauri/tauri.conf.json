{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dra Cami Contractual",
  "version": "1.0.0",
  "identifier": "co.gov.fiscalia.feab.dra-cami",
  "build": {
    "frontendDist": "../app/out",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sistema de Seguimiento Contratos FEAB · Dra Cami",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5QjlBRTE5QzJDNERGNzAKUldSdzM4VENHYTY1T1NFQm8vdXhsOVdtWEU5bHVsaVVIdjViNUhlQ05mRjdJNzZIM29TdTQyMWUK",
      "endpoints": [
        "https://github.com/smarroquinc10/14-SECOP-Dr-Camila-Mendoza/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/dra-cami-api.exe"
    ],
    "copyright": "© FEAB · Fiscalía General de la Nación",
    "category": "Business",
    "shortDescription": "Espejo automático del SECOP II para FEAB.",
    "longDescription": "Sistema institucional de seguimiento contractual del Fondo Especial para la Administración de Bienes (FEAB), Fiscalía General de la Nación. Espejo del SECOP II en tiempo real, con audit-log inmutable y lectura directa del portal cuando la API pública no expone un proceso.",
    "windows": {
      "wix": {
        "language": ["es-ES"]
      }
    }
  }
}
