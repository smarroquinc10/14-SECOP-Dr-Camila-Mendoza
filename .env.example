# App Token opcional de datos.gov.co (obtenerlo gratis en https://www.datos.gov.co/profile/edit/developer_settings)
# Sin token Socrata aplica throttling agresivo (429). Con token: 1000 req/hora.
SOCRATA_APP_TOKEN=

# Rate limit (requests por segundo) - por defecto 2 sin token / 5 con token
SECOP_RATE_LIMIT=2
